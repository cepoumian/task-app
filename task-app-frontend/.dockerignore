# ============================================
# .dockerignore - Optimización del Build Context
# ============================================

# Dependencias (se instalan en el Dockerfile)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs de Next.js
.next
out

# Testing
coverage
.nyc_output

# Misc
.DS_Store
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo
*~

# Env files (NUNCA incluir secretos)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Docker
Dockerfile
.dockerignore
docker-compose*.yml

# Documentation
README.md
CHANGELOG.md
LICENSE

# ============================================
# ¿POR QUÉ ESTO ES IMPORTANTE?
# ============================================
# 1. Reduce tamaño del build context
#    - Menos archivos a enviar al daemon
#    - Build más rápido
#
# 2. Evita invalidar cache innecesariamente
#    - .git changes no afectan el build
#    - IDE configs no afectan el build
#
# 3. Seguridad
#    - .env no se copia accidentalmente
#    - Secretos no terminan en la imagen
#
# 4. Limpieza
#    - Solo código necesario en la imagen
#
# IMPACTO:
# - Build context: ~500KB vs ~50MB sin .dockerignore
# - Build time: -30% más rápido
# ============================================
