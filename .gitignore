# ============================================
# .gitignore - task-app monorepo
# task-app-frontend + task-app-backend
# ============================================

# ─── Dependencias ───────────────────────────
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Builds ─────────────────────────────────
# Next.js
.next/
out/

# TypeScript (backend)
dist/
build/

# ─── Variables de entorno ───────────────────
# NUNCA versionar secretos
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ─── Docker ─────────────────────────────────
# Volúmenes locales si los montas como bind mount
docker/data/
postgres-data/

# ─── Sistema Operativo ───────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDEs ────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ─── TypeScript ──────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing ─────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ────────────────────────────────────
*.log
*.tmp
*.temp
.cache/
.vercel/